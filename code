<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Taskboard">
<meta name="theme-color" content="#f5f0e8">
<title>Taskboard</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:           #f5f0e8;
    --surface:      #fffdf7;
    --surface2:     #f0ead8;
    --border:       #ddd5c0;
    --border-light: #e8e0cc;
    --accent:       #8b6914;
    --accent-dim:   #b8960f;
    --accent-light: #f5e9c8;
    --text:         #2c2416;
    --text-muted:   #7a6a4f;
    --text-dim:     #b0a080;
    --done-bg:      #f2f5ee;
    --done-border:  #d4dcca;
    --done-accent:  #4e7a35;
    --red:          #c0392b;
    --red-light:    #fdf0ee;
    --shadow:       rgba(60,40,10,0.08);
    --today-bg:     #eef3f8;
    --today-border: #c8d8e8;
    --today-accent: #2e6da0;
    --today-light:  #ddeaf6;
    --tab-h:        56px;
    --safe-bottom:  env(safe-area-inset-bottom, 0px);
    --safe-top:     env(safe-area-inset-top, 0px);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  html, body {
    height: 100%;
    overscroll-behavior: none;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    position: fixed; width: 100%; overflow: hidden;
    background-image: repeating-linear-gradient(
      0deg, transparent, transparent 27px,
      rgba(180,160,110,0.06) 27px, rgba(180,160,110,0.06) 28px
    );
  }

  .app {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    padding-top: var(--safe-top);
  }

  .app-header {
    flex-shrink: 0;
    padding: 18px 20px 12px;
    background: var(--bg);
    border-bottom: 1px solid var(--border-light);
  }

  .app-header-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
  }

  .app-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .app-title span { color: var(--accent); }

  .app-date {
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    padding-bottom: 3px;
    text-align: right;
    line-height: 1.4;
  }

  .panels {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .panel {
    display: none;
    position: absolute;
    inset: 0;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 16px 16px calc(var(--tab-h) + var(--safe-bottom) + 16px);
  }

  .panel.active { display: block; }

  .tab-bar {
    flex-shrink: 0;
    display: flex;
    background: rgba(255,253,247,0.95);
    border-top: 1px solid var(--border-light);
    padding-bottom: var(--safe-bottom);
    height: calc(var(--tab-h) + var(--safe-bottom));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .tab-bar-btn {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 4px;
    color: var(--text-dim);
    transition: color 0.15s;
    -webkit-tap-highlight-color: transparent;
  }

  .tab-bar-btn.active { color: var(--accent); }

  .tab-bar-icon {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tab-bar-icon svg { width: 22px; height: 22px; }

  .tab-bar-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
    margin-top: 24px;
  }

  .section-header:first-child { margin-top: 0; }

  .section-title {
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .section-count { font-size: 10px; color: var(--text-dim); }
  .section-line { flex: 1; height: 1px; background: var(--border-light); }

  .add-row {
    display: flex;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 2px 8px var(--shadow);
    margin-bottom: 20px;
  }

  .add-row input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 15px;
    padding: 14px 16px;
    min-height: 48px;
  }

  .add-row input::placeholder { color: var(--text-dim); }

  .add-row button {
    background: var(--accent);
    border: none;
    color: #fff;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0 18px;
    cursor: pointer;
    white-space: nowrap;
    min-height: 48px;
    min-width: 72px;
  }

  .task-list {
    list-style: none;
    background: var(--surface);
    border-radius: 14px;
    border: 1px solid var(--border-light);
    box-shadow: 0 2px 10px var(--shadow);
    overflow: hidden;
    margin-bottom: 8px;
  }

  .task-item {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border-light);
    background: var(--surface);
    position: relative;
    overflow: hidden;
    min-height: 52px;
  }

  .task-item:last-child { border-bottom: none; }

  .task-item-inner {
    display: flex;
    align-items: center;
    width: 100%;
    min-height: 52px;
    background: var(--surface);
    position: relative;
    z-index: 1;
    transition: transform 0.2s ease;
  }

  .task-swipe-action {
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 80px;
    background: var(--red);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    z-index: 0;
  }

  .task-num {
    font-size: 10px;
    color: var(--text-dim);
    width: 32px;
    flex-shrink: 0;
    text-align: center;
    user-select: none;
  }

  .task-check {
    width: 28px;
    height: 28px;
    border: 2px solid var(--border);
    border-radius: 8px;
    flex-shrink: 0;
    margin: 0 12px 0 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
    transition: border-color 0.15s, background 0.15s;
  }

  .task-check:active { border-color: var(--accent); background: var(--accent-light); }
  .task-check svg { display: none; width: 14px; height: 14px; stroke: var(--accent); }

  .task-text {
    flex: 1;
    font-size: 15px;
    line-height: 1.5;
    color: var(--text);
    padding: 14px 0;
    word-break: break-word;
    outline: none;
  }

  .task-text:focus { color: var(--accent); }

  .reorder-handle {
    flex-shrink: 0;
    width: 44px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    touch-action: none;
  }

  .reorder-handle svg { width: 18px; height: 18px; }

  .task-item.reorder-dragging .task-item-inner {
    background: var(--accent-light);
    box-shadow: 0 4px 16px var(--shadow);
  }

  .task-item.reorder-drag-over { border-top: 2px solid var(--accent) !important; }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .today-section { margin-bottom: 8px; }
  .today-section .section-title { color: var(--today-accent); }

  .today-clear-btn {
    background: none;
    border: 1px solid var(--today-border);
    color: var(--today-accent);
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 6px;
    cursor: pointer;
    flex-shrink: 0;
    min-height: 30px;
  }

  .today-box {
    background: var(--today-bg);
    border: 1px solid var(--today-border);
    border-radius: 14px;
    overflow: hidden;
  }

  .today-add-row {
    display: flex;
    border-bottom: 1px solid var(--today-border);
  }

  #new-today-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    padding: 13px 14px;
    min-height: 48px;
  }

  #new-today-input::placeholder { color: var(--text-dim); }

  #add-today-btn {
    background: none;
    border: none;
    border-left: 1px solid var(--today-border);
    color: var(--today-accent);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0 14px;
    cursor: pointer;
    min-height: 48px;
    min-width: 60px;
  }

  .today-empty {
    text-align: center;
    padding: 24px 0;
    color: var(--today-accent);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.4;
  }

  .today-list { list-style: none; }

  .today-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px 12px 10px;
    border-bottom: 1px solid var(--today-border);
    min-height: 48px;
    animation: slideIn 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .today-item:last-child { border-bottom: none; }
  .today-item.today-drag-over { border-top: 2px solid var(--today-accent) !important; }

  .today-reorder-handle {
    flex-shrink: 0;
    width: 36px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    touch-action: none;
  }

  .today-reorder-handle svg { width: 16px; height: 16px; }

  .today-bullet {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--today-accent); flex-shrink: 0; opacity: 0.7;
  }

  .today-text {
    flex: 1;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text);
    outline: none;
    word-break: break-word;
  }

  .today-text:focus { color: var(--accent); }

  .today-delete {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--text-dim);
    font-size: 20px;
    line-height: 1;
    padding: 0 4px;
    min-width: 36px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .today-delete:active { color: var(--red); }

  .done-section .section-title { color: var(--done-accent); opacity: 0.85; }

  .done-list {
    list-style: none;
    background: var(--done-bg);
    border-radius: 14px;
    border: 1px solid var(--done-border);
    overflow: hidden;
  }

  .done-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-bottom: 1px solid var(--done-border);
    min-height: 52px;
    animation: slideIn 0.2s ease;
  }

  .done-item:last-child { border-bottom: none; }

  .done-check {
    width: 28px; height: 28px;
    border: 2px solid var(--done-accent);
    border-radius: 8px;
    flex-shrink: 0;
    background: var(--done-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .done-check svg { width: 14px; height: 14px; stroke: #fff; }

  .done-text-wrap { flex: 1; min-width: 0; }

  .done-text {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-muted);
    text-decoration: line-through;
    text-decoration-color: var(--text-dim);
    word-break: break-word;
  }

  .done-sub {
    display: flex;
    gap: 10px;
    margin-top: 2px;
    align-items: center;
  }

  .done-expiry { font-size: 9px; color: var(--text-dim); letter-spacing: 0.06em; }
  .done-item.expiring-soon .done-expiry { color: #b87a20; }
  .done-meta { font-size: 9px; color: var(--text-dim); letter-spacing: 0.04em; }

  .done-restore {
    background: none;
    border: 1px solid var(--done-border);
    color: var(--text-dim);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.06em;
    padding: 5px 10px;
    border-radius: 6px;
    cursor: pointer;
    flex-shrink: 0;
    min-height: 34px;
    white-space: nowrap;
  }

  .done-restore:active { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }

  .note-add-area {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 8px var(--shadow);
    margin-bottom: 20px;
  }

  #new-note-input {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    padding: 14px 16px 10px;
    resize: none;
    line-height: 1.7;
    min-height: 80px;
    display: block;
  }

  #new-note-input::placeholder { color: var(--text-dim); }

  .note-add-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 8px 12px 10px;
    border-top: 1px solid var(--border-light);
  }

  #add-note-btn {
    background: var(--accent);
    border: none;
    color: #fff;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 10px 18px;
    border-radius: 8px;
    cursor: pointer;
    min-height: 40px;
  }

  .notes-list { display: flex; flex-direction: column; gap: 12px; }

  .note-card {
    background: var(--surface);
    border: 1px solid var(--border-light);
    border-radius: 14px;
    box-shadow: 0 2px 8px var(--shadow);
    overflow: hidden;
    animation: slideIn 0.2s ease;
  }

  .note-card:nth-child(4n+1) { background: #fffdf7; }
  .note-card:nth-child(4n+2) { background: #fdf8ee; }
  .note-card:nth-child(4n+3) { background: #f8fdf3; border-color: #d4dcca; }
  .note-card:nth-child(4n+4) { background: #fdf5f5; border-color: #e0cecc; }

  .note-body {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text);
    padding: 14px 16px 10px;
    outline: none;
    word-break: break-word;
    white-space: pre-wrap;
    min-height: 60px;
  }

  .note-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border-light);
    padding: 8px 14px;
  }

  .note-date { font-size: 10px; color: var(--text-dim); letter-spacing: 0.06em; }

  .note-delete {
    background: none;
    border: none;
    color: var(--text-dim);
    font-size: 20px;
    line-height: 1;
    padding: 0 4px;
    min-width: 44px;
    min-height: 36px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    cursor: pointer;
  }

  .note-delete:active { color: var(--red); }

  .notes-empty {
    text-align: center;
    padding: 40px 0;
    color: var(--text-dim);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .empty-state {
    text-align: center;
    padding: 28px 0;
    color: var(--text-dim);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .toast {
    position: fixed;
    bottom: calc(var(--tab-h) + var(--safe-bottom) + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: rgba(44,36,22,0.88);
    color: #fffdf7;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    padding: 10px 20px;
    border-radius: 20px;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    pointer-events: none;
    z-index: 10000;
    white-space: nowrap;
  }

  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
</style>
</head>
<body>

<div class="app">
  <div class="app-header">
    <div class="app-header-row">
      <div class="app-title">Task<span>board</span></div>
      <div class="app-date" id="date-display"></div>
    </div>
  </div>

  <div class="panels">
    <div class="panel active" id="panel-tasks">
      <div class="add-row">
        <input type="text" id="new-task-input" placeholder="Add a new task…" maxlength="300" autocomplete="off" autocorrect="off" />
        <button id="add-btn">Add</button>
      </div>
      <div class="section-header">
        <span class="section-title">To Do</span>
        <span class="section-count" id="todo-count"></span>
        <div class="section-line"></div>
      </div>
      <ul class="task-list" id="todo-list"></ul>
      <div class="today-section">
        <div class="section-header">
          <span class="section-title" style="color:var(--today-accent)">Done Today</span>
          <span class="section-count" id="today-count"></span>
          <div class="section-line" style="background:var(--today-border)"></div>
          <button class="today-clear-btn" id="clear-today-btn" style="display:none">Clear</button>
        </div>
        <div class="today-box">
          <div class="today-add-row">
            <input type="text" id="new-today-input" placeholder="Add something done…" maxlength="300" autocomplete="off" />
            <button id="add-today-btn">Add</button>
          </div>
          <ul class="today-list" id="today-list"></ul>
          <div class="today-empty" id="today-empty">Nothing yet</div>
        </div>
      </div>
      <div class="done-section">
        <div class="section-header">
          <span class="section-title">Completed</span>
          <span class="section-count" id="done-count"></span>
          <div class="section-line"></div>
        </div>
        <ul class="done-list" id="done-list"></ul>
      </div>
    </div>

    <div class="panel" id="panel-notes">
      <div class="note-add-area">
        <textarea id="new-note-input" placeholder="Write a note…" spellcheck="true" maxlength="2000"></textarea>
        <div class="note-add-footer">
          <button id="add-note-btn">Save Note</button>
        </div>
      </div>
      <div class="section-header" style="margin-top:0">
        <span class="section-title">Notes</span>
        <span class="section-count" id="notes-count"></span>
        <div class="section-line"></div>
      </div>
      <div class="notes-list" id="notes-list"></div>
    </div>
  </div>

  <div class="tab-bar">
    <button class="tab-bar-btn active" data-tab="tasks">
      <div class="tab-bar-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="5" width="18" height="16" rx="2"/>
          <polyline points="7,10 9.5,13 13,8.5"/>
          <line x1="14" y1="10" x2="19" y2="10"/>
          <polyline points="7,16 9.5,19 13,14.5"/>
          <line x1="14" y1="16" x2="19" y2="16"/>
        </svg>
      </div>
      <span class="tab-bar-label">Tasks</span>
    </button>
    <button class="tab-bar-btn" data-tab="notes">
      <div class="tab-bar-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <line x1="7" y1="8" x2="17" y2="8"/>
          <line x1="7" y1="12" x2="17" y2="12"/>
          <line x1="7" y1="16" x2="13" y2="16"/>
        </svg>
      </div>
      <span class="tab-bar-label">Notes</span>
    </button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  const STORAGE_KEY = 'taskboard_v1';
  const WEEK_MS = 7 * 24 * 60 * 60 * 1000;
  let state = { todos: [], done: [], notes: [], today: [] };

  function load() {
    try { const r = localStorage.getItem(STORAGE_KEY); if (r) state = JSON.parse(r); } catch(e) {}
    state.todos = state.todos || [];
    state.done  = state.done  || [];
    state.notes = state.notes || [];
    state.today = state.today || [];
  }

  function save() { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }

  function purgeExpired() {
    const before = state.done.length;
    state.done = state.done.filter(d => (Date.now() - d.completedAt) < WEEK_MS);
    if (state.done.length !== before) save();
  }

  function render() { renderTodos(); renderDone(); renderToday(); renderNotes(); updateDate(); }

  const TICK = `<svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="1.5,6 5,9.5 10.5,2.5"/></svg>`;

  const REORDER_ICON = `<svg viewBox="0 0 20 20" fill="currentColor" opacity="0.4">
    <rect x="3" y="5"  width="14" height="2" rx="1"/>
    <rect x="3" y="9"  width="14" height="2" rx="1"/>
    <rect x="3" y="13" width="14" height="2" rx="1"/>
  </svg>`;

  function updateDate() {
    const d = new Date();
    const days   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    document.getElementById('date-display').innerHTML =
      `${days[d.getDay()]} ${d.getDate()} ${months[d.getMonth()]}<br>${d.getFullYear()}`;
  }

  function formatDate(ts) {
    const d = new Date(ts);
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return `${d.getDate()} ${months[d.getMonth()]} ${d.getHours().toString().padStart(2,'0')}:${d.getMinutes().toString().padStart(2,'0')}`;
  }

  function renderTodos() {
    const list  = document.getElementById('todo-list');
    const count = document.getElementById('todo-count');
    list.innerHTML = '';
    if (state.todos.length === 0) {
      count.textContent = '';
      list.innerHTML = '<li class="empty-state">Nothing here yet</li>';
      return;
    }
    count.textContent = `(${state.todos.length})`;
    state.todos.forEach((task, i) => {
      const li = document.createElement('li');
      li.className = 'task-item';
      li.dataset.index = i;
      const swipeBg = document.createElement('div');
      swipeBg.className = 'task-swipe-action';
      swipeBg.textContent = 'Delete';
      const inner = document.createElement('div');
      inner.className = 'task-item-inner';
      const num = document.createElement('div');
      num.className = 'task-num';
      num.textContent = i + 1;
      const check = document.createElement('div');
      check.className = 'task-check';
      check.innerHTML = TICK;
      check.addEventListener('click', e => { e.stopPropagation(); completeTask(i); });
      const text = document.createElement('div');
      text.className = 'task-text';
      text.textContent = task.text;
      text.contentEditable = true;
      text.spellcheck = false;
      text.addEventListener('blur', () => {
        const v = text.textContent.trim();
        if (v && v !== task.text) { state.todos[i].text = v; save(); }
        else if (!v) text.textContent = task.text;
      });
      text.addEventListener('keydown', e => {
        if (e.key === 'Enter') { e.preventDefault(); text.blur(); }
      });
      const handle = document.createElement('div');
      handle.className = 'reorder-handle';
      handle.innerHTML = REORDER_ICON;
      inner.append(num, check, text, handle);
      li.append(swipeBg, inner);
      attachSwipeDelete(li, inner, () => deleteTask(i));
      attachTouchReorder(handle, li, i, 'todos', () => { save(); renderTodos(); });
      list.appendChild(li);
    });
  }

  function attachSwipeDelete(li, inner, onDelete) {
    let startX = null, startY = null, swiping = false;
    const THRESHOLD = 72;
    inner.addEventListener('touchstart', e => {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      swiping = false;
    }, { passive: true });
    inner.addEventListener('touchmove', e => {
      if (startX === null) return;
      const dx = e.touches[0].clientX - startX;
      const dy = Math.abs(e.touches[0].clientY - startY);
      if (!swiping && dy > 10) { startX = null; return; }
      if (dx < -8) { swiping = true; }
      if (swiping && dx < 0) {
        e.preventDefault();
        inner.style.transform = `translateX(${Math.max(-THRESHOLD - 8, dx)}px)`;
      }
    }, { passive: false });
    inner.addEventListener('touchend', e => {
      if (!swiping) { startX = null; return; }
      const dx = e.changedTouches[0].clientX - startX;
      if (dx < -THRESHOLD) {
        inner.style.transform = `translateX(-100%)`;
        inner.style.transition = 'transform 0.2s ease';
        setTimeout(onDelete, 180);
      } else {
        inner.style.transform = '';
        inner.style.transition = 'transform 0.2s ease';
        setTimeout(() => inner.style.transition = '', 200);
      }
      startX = null; swiping = false;
    }, { passive: true });
  }

  function attachTouchReorder(handle, li, idx, arrayKey, onDone) {
    let longPressTimer = null;
    let dragging = false;
    let startY, lastY;
    handle.addEventListener('touchstart', e => {
      e.stopPropagation();
      startY = e.touches[0].clientY;
      lastY  = startY;
      longPressTimer = setTimeout(() => {
        dragging = true;
        li.classList.add('reorder-dragging');
        navigator.vibrate && navigator.vibrate(30);
      }, 200);
    }, { passive: true });
    handle.addEventListener('touchmove', e => {
      lastY = e.touches[0].clientY;
      if (!dragging) return;
      e.preventDefault();
      const list = li.parentElement;
      const items = Array.from(list.querySelectorAll('.task-item, .today-item'));
      items.forEach(item => item.classList.remove('reorder-drag-over', 'today-drag-over'));
      const target = items.find(item => {
        if (item === li) return false;
        const r = item.getBoundingClientRect();
        return lastY >= r.top && lastY <= r.bottom;
      });
      if (target) target.classList.add(arrayKey === 'today' ? 'today-drag-over' : 'reorder-drag-over');
    }, { passive: false });
    handle.addEventListener('touchend', e => {
      clearTimeout(longPressTimer);
      if (!dragging) return;
      dragging = false;
      li.classList.remove('reorder-dragging');
      const list = li.parentElement;
      const items = Array.from(list.querySelectorAll('.task-item, .today-item'));
      items.forEach(item => item.classList.remove('reorder-drag-over', 'today-drag-over'));
      const target = items.find(item => {
        if (item === li) return false;
        const r = item.getBoundingClientRect();
        return lastY >= r.top && lastY <= r.bottom;
      });
      if (target) {
        const targetIdx = parseInt(target.dataset.index !== undefined ? target.dataset.index : target.dataset.todayIndex);
        const arr = state[arrayKey];
        const moved = arr.splice(idx, 1)[0];
        const adjustedTarget = targetIdx > idx ? targetIdx - 1 : targetIdx;
        arr.splice(adjustedTarget, 0, moved);
        onDone();
        toast('Reordered');
      }
    }, { passive: true });
  }

  function renderDone() {
    const list  = document.getElementById('done-list');
    const count = document.getElementById('done-count');
    list.innerHTML = '';
    if (state.done.length === 0) {
      count.textContent = '';
      list.innerHTML = '<li class="empty-state">No completed tasks</li>';
      return;
    }
    count.textContent = `(${state.done.length})`;
    const now = Date.now();
    state.done.forEach((task, i) => {
      const remaining = WEEK_MS - (now - task.completedAt);
      const daysLeft  = Math.ceil(remaining / 86400000);
      const li = document.createElement('li');
      li.className = 'done-item' + (daysLeft <= 1 ? ' expiring-soon' : '');
      const check = document.createElement('div');
      check.className = 'done-check';
      check.innerHTML = TICK;
      const textWrap = document.createElement('div');
      textWrap.className = 'done-text-wrap';
      const text = document.createElement('div');
      text.className = 'done-text';
      text.textContent = task.text;
      const sub = document.createElement('div');
      sub.className = 'done-sub';
      const meta = document.createElement('span');
      meta.className = 'done-meta';
      meta.textContent = formatDate(task.completedAt);
      const expiry = document.createElement('span');
      expiry.className = 'done-expiry';
      expiry.textContent = daysLeft <= 1 ? '· deletes today' : `· ${daysLeft}d left`;
      sub.append(meta, expiry);
      textWrap.append(text, sub);
      const restore = document.createElement('button');
      restore.className = 'done-restore';
      restore.textContent = '↩ Undo';
      restore.addEventListener('click', () => uncompleteTask(i));
      li.append(check, textWrap, restore);
      list.appendChild(li);
    });
  }

  function renderToday() {
    const list    = document.getElementById('today-list');
    const count   = document.getElementById('today-count');
    const empty   = document.getElementById('today-empty');
    const clearBtn = document.getElementById('clear-today-btn');
    list.innerHTML = '';
    const hasItems = state.today.length > 0;
    count.textContent = hasItems ? `(${state.today.length})` : '';
    empty.style.display = hasItems ? 'none' : '';
    if (clearBtn) clearBtn.style.display = hasItems ? '' : 'none';
    state.today.forEach((item, i) => {
      const li = document.createElement('li');
      li.className = 'today-item';
      li.dataset.todayIndex = i;
      const handle = document.createElement('div');
      handle.className = 'today-reorder-handle';
      handle.innerHTML = REORDER_ICON;
      const bullet = document.createElement('div');
      bullet.className = 'today-bullet';
      const text = document.createElement('div');
      text.className = 'today-text';
      text.textContent = item;
      text.contentEditable = true;
      text.spellcheck = true;
      text.addEventListener('blur', () => {
        const v = text.textContent.trim();
        if (v && v !== state.today[i]) { state.today[i] = v; save(); }
        else if (!v) text.textContent = state.today[i];
      });
      text.addEventListener('keydown', e => {
        if (e.key === 'Enter') { e.preventDefault(); text.blur(); }
      });
      const del = document.createElement('button');
      del.className = 'today-delete';
      del.innerHTML = '×';
      del.addEventListener('click', () => {
        state.today.splice(i, 1);
        save(); renderToday(); toast('Removed');
      });
      li.append(handle, bullet, text, del);
      attachTouchReorder(handle, li, i, 'today', () => { save(); renderToday(); });
      list.appendChild(li);
    });
  }

  function renderNotes() {
    const list  = document.getElementById('notes-list');
    const count = document.getElementById('notes-count');
    list.innerHTML = '';
    if (state.notes.length === 0) {
      count.textContent = '';
      list.innerHTML = '<div class="notes-empty">No notes yet</div>';
      return;
    }
    count.textContent = `(${state.notes.length})`;
    state.notes.forEach((note, i) => {
      const card = document.createElement('div');
      card.className = 'note-card';
      const body = document.createElement('div');
      body.className = 'note-body';
      body.contentEditable = true;
      body.spellcheck = true;
      body.textContent = note.text;
      body.addEventListener('blur', () => {
        const v = body.textContent.trim();
        if (v !== note.text) {
          if (v) { state.notes[i].text = v; save(); }
          else body.textContent = note.text;
        }
      });
      const footer = document.createElement('div');
      footer.className = 'note-footer';
      const date = document.createElement('div');
      date.className = 'note-date';
      date.textContent = formatDate(note.createdAt);
      const del = document.createElement('button');
      del.className = 'note-delete';
      del.innerHTML = '×';
      del.addEventListener('click', () => {
        state.notes.splice(i, 1);
        save(); renderNotes(); toast('Note deleted');
      });
      footer.append(date, del);
      card.append(body, footer);
      list.appendChild(card);
    });
  }

  function addTask(text) {
    if (!text.trim()) return;
    state.todos.push({ id: Date.now(), text: text.trim(), createdAt: Date.now() });
    save(); render(); toast('Task added');
  }

  function completeTask(i) {
    const task = state.todos.splice(i, 1)[0];
    task.completedAt = Date.now();
    state.done.unshift(task);
    state.today.push(task.text);
    save(); render(); toast('Done ✓');
  }

  function uncompleteTask(i) {
    const task = state.done.splice(i, 1)[0];
    delete task.completedAt;
    state.todos.push(task);
    save(); render(); toast('Restored');
  }

  function deleteTask(i) {
    state.todos.splice(i, 1);
    save(); render(); toast('Deleted');
  }

  function addNote(text) {
    if (!text.trim()) return;
    state.notes.push({ id: Date.now(), text: text.trim(), createdAt: Date.now() });
    save(); renderNotes();
    document.getElementById('notes-count').textContent = `(${state.notes.length})`;
    toast('Note saved');
  }

  let toastTimer;
  function toast(msg) {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => el.classList.remove('show'), 2000);
  }

  document.querySelectorAll('.tab-bar-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-bar-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
    });
  });

  document.getElementById('add-btn').addEventListener('click', () => {
    const input = document.getElementById('new-task-input');
    addTask(input.value); input.value = ''; input.blur();
  });

  document.getElementById('new-task-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') { addTask(e.target.value); e.target.value = ''; e.target.blur(); }
  });

  document.getElementById('clear-today-btn').addEventListener('click', () => {
    if (!state.today.length) return;
    state.today = [];
    save(); renderToday(); toast('Done Today cleared');
  });

  document.getElementById('add-today-btn').addEventListener('click', () => {
    const input = document.getElementById('new-today-input');
    if (!input.value.trim()) return;
    state.today.push(input.value.trim());
    save(); renderToday(); input.value = ''; input.blur();
    toast('Added');
  });

  document.getElementById('new-today-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      if (!e.target.value.trim()) return;
      state.today.push(e.target.value.trim());
      save(); renderToday(); e.target.value = ''; e.target.blur();
      toast('Added');
    }
  });

  document.getElementById('add-note-btn').addEventListener('click', () => {
    const input = document.getElementById('new-note-input');
    addNote(input.value); input.value = ''; input.blur();
  });

  load();
  purgeExpired();
  render();
  setInterval(() => { purgeExpired(); render(); }, 3600000);
</script>
</body>
</html>
